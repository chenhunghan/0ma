{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-ask",
    "dialog:allow-message",
    "store:default",
    "log:default",
    "updater:default",
    "process:allow-restart"
  ]
}
