{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "src-tauri": {
      "release-type": "rust",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": false,
      "include-paths": ["src-tauri/", "src/", "public/", "index.html", "package.json", "package-lock.json", "vite.config.ts", "tsconfig.json", "tsconfig.node.json", "postcss.config.js"],
      "extra-files": [
        {
          "type": "json",
          "path": "tauri.conf.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
